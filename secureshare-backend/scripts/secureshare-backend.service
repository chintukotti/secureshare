[Unit]
Description=SecureShare FastAPI Backend
After=network.target

[Service]
User=ec2-user
WorkingDirectory=/home/ec2-user/secureshare-backend
EnvironmentFile=/home/ec2-user/secureshare-backend/.env
ExecStart=/home/ec2-user/secureshare-backend/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000
StandardOutput=append:/var/log/secureshare-backend.log
StandardError=append:/var/log/secureshare-backend.log
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
