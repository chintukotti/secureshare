{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "S3FileAccess",
      "Effect": "Allow",
      "Action": ["s3:PutObject", "s3:GetObject", "s3:DeleteObject", "s3:CopyObject"],
      "Resource": "arn:aws:s3:::REPLACE_BUCKET_NAME/*"
    },
    {
      "Sid": "DynamoDBAccess",
      "Effect": "Allow",
      "Action": ["dynamodb:GetItem", "dynamodb:PutItem", "dynamodb:UpdateItem", "dynamodb:DeleteItem", "dynamodb:Query", "dynamodb:Scan"],
      "Resource": [
        "arn:aws:dynamodb:ap-south-1:REPLACE_ACCOUNT_ID:table/secureshare-dev-users",
        "arn:aws:dynamodb:ap-south-1:REPLACE_ACCOUNT_ID:table/secureshare-dev-items",
        "arn:aws:dynamodb:ap-south-1:REPLACE_ACCOUNT_ID:table/secureshare-dev-share-links",
        "arn:aws:dynamodb:ap-south-1:REPLACE_ACCOUNT_ID:table/secureshare-dev-activity-logs",
        "arn:aws:dynamodb:ap-south-1:REPLACE_ACCOUNT_ID:table/secureshare-dev-download-events"
      ]
    },
    {
      "Sid": "CognitoAccess",
      "Effect": "Allow",
      "Action": ["cognito-idp:SignUp", "cognito-idp:ConfirmSignUp", "cognito-idp:InitiateAuth", "cognito-idp:GetUser", "cognito-idp:GlobalSignOut", "cognito-idp:ForgotPassword", "cognito-idp:ConfirmForgotPassword", "cognito-idp:ChangePassword"],
      "Resource": "arn:aws:cognito-idp:ap-south-1:REPLACE_ACCOUNT_ID:userpool/REPLACE_USER_POOL_ID"
    },
    {
      "Sid": "SNSPublish",
      "Effect": "Allow",
      "Action": ["sns:Publish"],
      "Resource": "arn:aws:sns:ap-south-1:REPLACE_ACCOUNT_ID:secureshare-dev-notifications"
    }
  ]
}
